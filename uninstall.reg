Windows Registry Editor Version 5.00

; ============================================================
; UrlRouter - Unregister (HKCU)
; ============================================================

[HKEY_CURRENT_USER\Software\RegisteredApplications]
"UrlRouter"=-

[-HKEY_CURRENT_USER\Software\UrlRouter]
[-HKEY_CURRENT_USER\Software\Classes\UrlRouter.http]
[-HKEY_CURRENT_USER\Software\Classes\UrlRouter.https]
[-HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\App Paths\UrlRouter.exe]
