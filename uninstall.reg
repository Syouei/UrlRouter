Windows Registry Editor Version 5.00

; ============================================================
; UrlPrompt - Unregister (HKCU)
; ============================================================

[HKEY_CURRENT_USER\Software\RegisteredApplications]
"UrlPrompt"=-

[-HKEY_CURRENT_USER\Software\UrlPrompt]
[-HKEY_CURRENT_USER\Software\Classes\UrlPrompt.http]
[-HKEY_CURRENT_USER\Software\Classes\UrlPrompt.https]
[-HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\App Paths\UrlPrompt.exe]
